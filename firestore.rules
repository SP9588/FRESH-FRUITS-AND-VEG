rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 0. Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // 3. Global Helpers
    function isSignedIn() { return request.auth != null; }
    function isVerified() { return isSignedIn() && request.auth.token.email_verified == true; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isAdmin() { return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid)); }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // --- Entity Validations ---

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'role']) &&
             data.uid == request.auth.uid &&
             data.email is string &&
             data.role in ['customer', 'seller', 'admin'];
    }

    function isValidProduct(data) {
      return data.keys().hasAll(['name', 'sellerId', 'price', 'category']) &&
             data.name is string && data.name.size() <= 100 &&
             data.category is string &&
             data.price is number && data.price > 0 &&
             data.sellerId == request.auth.uid;
    }

    function isValidNotification(data) {
      return data.keys().hasAll(['userId', 'title', 'message', 'type']) &&
             data.userId is string &&
             data.title is string &&
             data.message is string &&
             data.type in ['low_stock', 'order_received', 'system'];
    }

    // --- Match Blocks ---

    // 1. Users Collection
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isVerified() && isValidUser(incoming()) && isValidId(userId);
      allow update: if isVerified() && isOwner(userId) && 
                    incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL', 'updatedAt']) &&
                    incoming().updatedAt == request.time;
    }

    // 2. Sellers Collection
    match /sellers/{sellerId} {
      allow read: if isSignedIn();
      allow create: if isVerified() && isOwner(sellerId) && isValidId(sellerId);
      allow update: if isVerified() && (isOwner(sellerId) || isAdmin()) &&
                    incoming().diff(existing()).affectedKeys().hasOnly(['businessName', 'farmName', 'phone', 'whatsapp', 'city', 'address', 'updatedAt']) &&
                    incoming().updatedAt == request.time;
    }

    // 3. Products Collection
    match /products/{productId} {
      allow read: if true; // Public marketplace
      allow create: if isVerified() && isValidProduct(incoming()) && isValidId(productId);
      allow update: if isVerified() && (
                      (existing().sellerId == request.auth.uid || isAdmin()) && 
                      incoming().diff(existing()).affectedKeys().hasAny(['name', 'price', 'discountPrice', 'stock', 'status', 'description', 'lowStockThreshold', 'updatedAt'])
                    ) || (
                      // Allow customers to decrement stock during purchase
                      incoming().diff(existing()).affectedKeys().hasOnly(['stock']) && 
                      incoming().stock < existing().stock
                    );
      allow delete: if isVerified() && (existing().sellerId == request.auth.uid || isAdmin());
    }

    // 4. Orders Collection
    match /orders/{orderId} {
      allow get: if isSignedIn() && (resource.data.customerId == request.auth.uid || resource.data.sellerId == request.auth.uid);
      allow list: if isSignedIn() && (resource.data.customerId == request.auth.uid || resource.data.sellerId == request.auth.uid);
      allow create: if isVerified() && incoming().customerId == request.auth.uid && isValidId(orderId);
      allow update: if isVerified() && (resource.data.sellerId == request.auth.uid || isAdmin()) &&
                    incoming().diff(existing()).affectedKeys().hasOnly(['status', 'updatedAt']) &&
                    incoming().updatedAt == request.time;
    }

    // 5. Notifications Collection
    match /notifications/{notificationId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isVerified() && isValidNotification(incoming()) && isValidId(notificationId);
      allow update: if isVerified() && resource.data.userId == request.auth.uid &&
                    incoming().diff(existing()).affectedKeys().hasOnly(['read']);
      allow delete: if isVerified() && resource.data.userId == request.auth.uid;
    }

    // 6. Settings Collection
    match /settings/{settingId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
  }
}
